{
  "name": "holo-voxel-hands",
  "version": "1.0.0",
  "description": "Aplicacao de realidade aumentada no navegador com rastreamento de maos para criar e manipular blocos holograficos 3D.",
  "type": "module",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,css,html}\"",
    "electron:start": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.17",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/three": "^0.169.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.holovoxelhands.app",
    "productName": "Holo Voxel Hands",
    "artifactName": "Holo-Voxel-Hands-${version}.exe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
